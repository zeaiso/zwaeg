// Copy to Local.xcconfig (gitignored) and fill in to sign builds for a real
// device or for the App Store. Simulator builds need none of this.
//
// Your Team ID: developer.apple.com > Account > Membership > Team ID.
DEVELOPMENT_TEAM = YOURTEAMID

// Forks: override the identifier prefix so bundle IDs, the app group and the
// iCloud container derive from YOUR reverse-domain instead of the upstream one.
// ZWAEG_BUNDLE_ID_PREFIX = com.example
